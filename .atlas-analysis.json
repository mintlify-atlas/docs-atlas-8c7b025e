  "keyFeatures": [
    "Animated SVG charts with dark/light mode support",
    "Historical snapshots with configurable retention",
    "Smart repository filtering by visibility, ownership, and stars",
    "Stargazer tracking with avatars and timestamps",
    "Email notifications with SMTP and adaptive thresholds",
    "Multi-language support (English, Spanish, Catalan, Italian)",
    "CSV, JSON, Markdown, and HTML report generation",
    "Shields.io-style badges",
    "Growth forecasting",
    "GitHub Enterprise Server support"
  ],
